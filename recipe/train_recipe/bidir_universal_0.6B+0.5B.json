{
    "model": {
        "base_model": "Qwen/Qwen3-0.6B",
        "teacher_model": "Qwen/Qwen2.5-0.5B-Instruct",
        "projector": {
            "type": "BidirectionalUniversalProjector",
            "params": {
                "universal_dim": 256,
                "hidden_dim": 512,
                "num_layers": 2,
                "dropout": 0.1,
                "initial_temperature": 1.0,
                "final_temperature": 0.001,
                "anneal_steps": 1929
            }
        },
        "mapping": "last_aligned",
        "loss_weights": {"AB": 1.0, "BA": 1.0, "AA": 1.0, "BB": 1.0}
    },
    "training": {
        "learning_rate": 1e-4,
        "weight_decay": 0.01,
        "num_epochs": 1,
        "max_length": 2048,
        "device": "cuda",
        "scheduler_type": "linear",
        "warmup_ratio": 0.1,
        "max_grad_norm": 1.0,
        "gradient_accumulation_steps": 8,
        "per_device_train_batch_size": 4,
        "num_processes": 8,
        "freeze": ["teacher", "base"],
        "seed": 42
    },
    "output": {
        "output_dir": "local/checkpoints/bidir_universal_0.6+0.5B",
        "save_steps": 500,
        "eval_steps": 100,
        "wandb_config": {
            "project": "Rosetta",
            "mode": "online",
            "entity": "nics-efc",
            "run_name": "bidir_universal_0.6B+0.5B"
        }
    },
    "data": {
        "type": "OpenHermesChatDataset",
        "kwargs": {
            "split": "train",
            "max_word_count": 2048,
            "num_samples": 500000
        },
        "train_ratio": 0.99
    }
}
